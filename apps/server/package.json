    "@ownlab/adapter-gemini-local": "workspace:*",
    "@ownlab/adapter-opencode-local": "workspace:*",
    "@ownlab/adapter-pi-local": "workspace:*",
    "@ownlab/adapter-utils": "workspace:*",
    "@ownlab/db": "workspace:*",
    "@ownlab/shared": "workspace:*",
    "ai": "^6.0.116",
    "cors": "^2.8.6",
    "detect-port": "^2.1.0",
    "embedded-postgres": "18.3.0-beta.16",
    "express": "^5.0.1",
    "ocrad.js": "^0.0.1",
