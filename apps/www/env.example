# -----------------------------------------------------------------------------
# Application URLs
# -----------------------------------------------------------------------------
# Hosted entry URL, e.g. https://ownlab.app
NEXT_PUBLIC_BASE_URL="http://localhost:3001"
# Logged-in product URL, e.g. https://app.ownlab.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Cloud Database
# -----------------------------------------------------------------------------
# Dedicated cloud database for apps/www (recommended: Neon)
WWW_DATABASE_URL=""
# Backward-compatible fallback if you want to reuse the ownlab-web style name
DATABASE_URL=""

# -----------------------------------------------------------------------------
# Better Auth
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# -----------------------------------------------------------------------------
# OAuth Providers (optional)
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Email (Resend, optional but recommended for reset password / verification)
# -----------------------------------------------------------------------------
RESEND_API_KEY=""
AUTH_FROM_EMAIL="OwnLab <no-reply@ownlab.app>"
AUTH_SUPPORT_EMAIL="support@ownlab.app"
