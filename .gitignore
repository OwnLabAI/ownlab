# Dependencies
node_modules/
.pnpm-store/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Environment files
.env
.env.*
!.env.example
!.env.*.example

# Build outputs and caches
dist/
build/
out/
coverage/
.next/
.vite/
.turbo/
tmp/
tmp-*/
*.tsbuildinfo

# Next.js and app-local framework outputs
apps/*/.next/
apps/*/.open-next/
apps/*/.wrangler/
apps/*/.content-collections/
apps/*/.source/
apps/*/next-env.d.ts
apps/*/.dev.vars
apps/*/.dev.vars.*
!apps/*/.dev.vars.example

# Database tool output
drizzle/meta/

# Certificates and OS files
*.pem
.DS_Store
certificates/
apps/*/certificates/

# Local editor / agent tooling
.vscode/
.agents/
.claude/
.claude/settings.local.json
.conductor/
.cursor/
.kiro/
apps/*/.agents/
apps/*/.claude/
apps/*/.conductor/
apps/*/.cursor/
apps/*/.kiro/

# Scratch / seed scripts (but not scripts/ dir)
check-*.mjs
!scripts/check-*.mjs
new-agent*.json
seed-*.mjs
packages/db/seed-*.mjs

# Temporary files
*.tmp
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Prompt / reference material not shipped with the product
ods/
