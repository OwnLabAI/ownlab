{
  "name": "ownlab-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run dev:server & pnpm run dev:app",
    "dev:server": "pnpm --filter @ownlab/server dev",
    "dev:app": "pnpm --filter @ownlab/app dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest",
    "test:run": "vitest run",
    "db:generate": "pnpm --filter @ownlab/db generate",
    "db:migrate": "pnpm --filter @ownlab/db exec tsx src/migrate.ts",
    "ownlab": "pnpm --filter ./apps/cli exec node --import tsx src/index.ts",
    "ownlab:run": "pnpm --filter ./apps/cli exec node dist/index.js"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.4",
  "pnpm": {
    "overrides": {
      "@esbuild-kit/core-utils>esbuild": "^0.25.12"
    }
  }
}
